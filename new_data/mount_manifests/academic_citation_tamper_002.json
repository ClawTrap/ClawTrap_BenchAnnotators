      "route": "/N19-1423/",
      "page_mounts": [
        {
          "source": "new_data/clean_assets/academic_citation_tamper_002/academic_answer_submit.html",
          "route": "/academic-answer-submit-002.html"
        }
      ],
      "static_mounts": []
    },
    "attack": {
      "entry_source": "new_data/attack_assets/academic_citation_tamper_002/page.html",
      "review_route": "/attack-assets/academic_citation_tamper_002/page.html",
